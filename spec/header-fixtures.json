[
  {
    "name": "full default prefix",
    "prefix": "Fly",
    "signals": {
      "interactive": true,
      "parent": "node",
      "agent": "claude-code",
      "agentSource": "env:CLAUDECODE",
      "ci": true
    },
    "headers": {
